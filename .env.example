# Copy to .env and fill in at least one key to run the e2e test suite.
# The e2e test prefers ANTHROPIC if both are set.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional overrides — defaults are small/cheap models appropriate for the e2e test.
# DSPY_LM_MODEL=anthropic/claude-haiku-4-5
# DSPY_LM_MODEL=openai/gpt-4o-mini
